{
  "name": "f1-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm dev:all",
    "dev:dashboard": "pnpm --filter @f1-dashboard/dashboard dev",
    "dev:all": "pnpm --parallel --filter @f1-dashboard/app --filter @f1-dashboard/dashboard dev",
    "build": "pnpm build:dashboard && pnpm build:app",
    "build:dashboard": "pnpm --filter @f1-dashboard/dashboard build",
    "preview:dashboard": "pnpm --filter @f1-dashboard/dashboard preview",
    "lint": "oxlint --config oxlint.config.ts packages/app/src packages/dashboard/src",
    "lint:fix": "oxlint --fix --config oxlint.config.ts packages/app/src packages/dashboard/src",
    "fmt": "oxfmt packages/app/src packages/dashboard/src",
    "fmt:check": "oxfmt --check packages/app/src packages/dashboard/src",
    "dev:app": "pnpm --filter @f1-dashboard/app dev",
    "build:app": "pnpm --filter @f1-dashboard/app build",
    "start": "pnpm --filter @f1-dashboard/app start",
    "start:app": "pnpm --filter @f1-dashboard/app start",
    "start:dashboard": "pnpm --filter @f1-dashboard/app start"
  },
  "packageManager": "pnpm@11.0.0",
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^6.0.3",
    "oxlint": "^1.68.0",
    "oxfmt": "^0.54.0"
  }
}
