{
  "name": "@f1-dashboard/app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "oxlint --config ../../oxlint.config.ts src/",
    "lint:fix": "oxlint --fix --config ../../oxlint.config.ts src/",
    "fmt": "oxfmt src/",
    "fmt:check": "oxfmt --check src/"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/http-proxy": "^11.0.0",
    "@fastify/static": "^8.0.0",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "18.19.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3"
  }
}
